{
  "lastChangelogVersion": "0.75.3",
  "defaultProvider": "github-copilot",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "medium",
  "compaction": {
    "enabled": false
  },
  "images": {
    "autoResize": true
  },
  "editorPaddingX": 1,
  "terminal": {
    "showTerminalProgress": false
  },
  "theme": "dark-blue-tint",
  "packages": [
    "npm:@juicesharp/rpiv-ask-user-question",
    {
      "source": "npm:@jerryan/pi-sanity",
      "extensions": [
        "+dist/extension.js"
      ]
    },
    {
      "source": "npm:pi-lens",
      "extensions": [
        "-index.ts"
      ],
      "skills": [
        "-skills/ast-grep/SKILL.md",
        "-skills/lsp-navigation/SKILL.md"
      ]
    },
    "npm:pi-rewind",
    "npm:@netandreus/pi-cursor-provider"
  ],
  "hideThinkingBlock": false,
  "collapseChangelog": false,
  "doubleEscapeAction": "tree"
}