{
  "providers": {
    "baseten": {
      "baseUrl": "https://inference.baseten.co/v1",
      "api": "openai-completions",
      "apiKey": "!jq -r '.baseten.key' ~/.pi/agent/auth.json",
      "authHeader": true,
      "models": [
        {
          "id": "zai-org/GLM-4.7",
          "name": "GLM 4.7",
          "input": ["text", "image"],
          "contextWindow": 128000,
          "maxTokens": 8192
        },
        {
          "id": "deepseek-ai/DeepSeek-V4",
          "name": "DeepSeek V4",
          "input": ["text"],
          "contextWindow": 128000,
          "maxTokens": 8192,
          "reasoning": true
        },
        {
          "id": "moonshotai/Kimi-K2.6",
          "name": "Kimi K2.6",
          "input": ["text", "image"],
          "contextWindow": 256000,
          "maxTokens": 8192
        },
        {
          "id": "MiniMaxAI/MiniMax-M2.5",
          "name": "MiniMax M2.5",
          "input": ["text"],
          "contextWindow": 128000,
          "maxTokens": 8192
        }
      ]
    }
  }
}
