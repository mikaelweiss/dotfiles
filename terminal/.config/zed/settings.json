// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "language_models": {
    "openai_compatible": {
      "Mac Mini": {
        "api_url": "https://wolf.tail243cc9.ts.net/v1",
        "available_models": [
          {
            "name": "qwen3-coder-30b",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          },
          {
            "name": "glm-4.7-flash",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true
            }
          }
        ]
      }
    }
  },
  "helix_mode": false,
  "git": {
    "inline_blame": {
      "show_commit_summary": false
    }
  },
  "agent": {
    "default_model": {
      "provider": "Mac Mini",
      "model": "glm-4.7-flash",
      "enable_thinking": false
    },
    "show_turn_stats": true,
    "message_editor_min_lines": 4,
    "single_file_review": true,
    "favorite_models": [],
    "play_sound_when_agent_done": true,
    "model_parameters": []
  },
  "terminal": {
    "font_weight": 400.0,
    "font_size": 12.0,
    "font_family": "MesloLGS NF"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "corust-agent": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "sweep": {
      "privacy_mode": true
    },
    "provider": "zed"
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_project_panel": true,
    "enable_preview_from_file_finder": false,
    "enable_preview_file_from_code_navigation": true
  },
  "tab_bar": {
    "show_nav_history_buttons": true
  },
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "base_keymap": "Cursor",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
}
