# Additionally, each config option is also explained in detail
# on Ghostty's website, at https://ghostty.org/docs/config.
font-family = "MesloLGS NF"
keybind = shift+enter=text:\n
keybind = shift+space=text:\x20
keybind = shift+backspace=text:\x7f

# option+digit sends ESC+digit so herdr sees alt+1..9 for switch_tab;
# macOS otherwise types ¡™£¢∞§¶•ª for these chords
keybind = alt+digit_1=esc:1
keybind = alt+digit_2=esc:2
keybind = alt+digit_3=esc:3
keybind = alt+digit_4=esc:4
keybind = alt+digit_5=esc:5
keybind = alt+digit_6=esc:6
keybind = alt+digit_7=esc:7
keybind = alt+digit_8=esc:8
keybind = alt+digit_9=esc:9

term = xterm-256color

background-opacity = 1.00