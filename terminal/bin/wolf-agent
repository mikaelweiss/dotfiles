#!/bin/zsh
# Runs on wolf, invoked over ssh by wolf-attach (which owns reconnects).
# Usage: wolf-agent <worktree_path> <name> [cmd...]
# Attaches to the per-worktree tmux keeper session, creating it (and starting
# the agent) if it doesn't exist. Waits for mutagen to materialize the
# directory when the laptop created it moments ago.
set -u
worktree=$1
name=${2//[.:]/-}
shift 2
cmd=${*:-'~/code/dotfiles/terminal/bin/wolf-bootstrap'}

waited=0
while [ ! -d "$worktree" ] && [ "$waited" -lt 120 ]; do
  sleep 0.5
  waited=$((waited + 1))
done
if [ ! -d "$worktree" ]; then
  echo "wolf-agent: $worktree has not synced over yet — check 'mutagen sync list' on the laptop" >&2
  exec zsh -l
fi

if ! tmux has-session -t "=$name" 2>/dev/null; then
  # Blank SSH_CONNECTION so /etc/zshrc's herdr auto-attach skips this session
  tmux new-session -d -s "$name" -c "$worktree" -e SSH_CONNECTION=
  tmux send-keys -t "=$name:" "$cmd" Enter
fi
# -d kicks any client left over from a dropped connection, so the session
# doesn't stay letterboxed at the dead client's size until sshd times it out
exec tmux attach-session -d -t "=$name"
