#!/bin/zsh
# Cleans up after a worktree is gone (wt remove, or wt merge with removal):
# kills the wolf keeper session, clears wolf's copy of the worktree (sync
# can't delete ignored files like node_modules), and closes the local tmux
# window / herdr tab. Closing the tab can kill the shell that ran wt, so
# that step is delayed and detached. Idempotent — safe to fire from both
# post-remove and post-merge.
# Usage: worktree-cleanup <branch> <branch-sanitized> <worktree_path>
branch=$1
rawname=$2
name=${2//[.:]/-}
worktree=$3

[ "$(hostname -s)" = "wolf" ] && exit 0

if [ -d "$worktree" ]; then
  # wt merge fires post-merge before its backgrounded removal deletes the
  # worktree — hand off to a detached copy that waits for it to vanish
  if [ -z "${WORKTREE_CLEANUP_REEXEC:-}" ]; then
    WORKTREE_CLEANUP_REEXEC=1 nohup "$0" "$branch" "$rawname" "$worktree" >/dev/null 2>&1 &!
    exit 0
  fi
  for i in {1..60}; do
    sleep 0.5
    [ -d "$worktree" ] || break
  done
  # still present after the wait: merge --no-remove, leave everything open
  [ -d "$worktree" ] && exit 0
fi

ssh -o BatchMode=yes -o ConnectTimeout=3 wolf "tmux kill-session -t \"=$name\"" >/dev/null 2>&1
case "$worktree" in
  "$HOME/.worktrees/"*)
    ssh -o BatchMode=yes -o ConnectTimeout=3 wolf "rm -rf '$worktree'" >/dev/null 2>&1
    ;;
esac

if [ -n "${HERDR_ENV:-}" ]; then
  tab_id=$(herdr tab list --workspace "$HERDR_WORKSPACE_ID" | jq -r --arg b "$branch" '.result.tabs[] | select(.label == $b) | .tab_id' | head -n1)
  [ -n "$tab_id" ] && nohup sh -c "sleep 1; herdr tab close $tab_id" >/dev/null 2>&1 &
elif [ -n "${TMUX:-}" ]; then
  nohup sh -c "sleep 1; tmux kill-window -t '=$branch'" >/dev/null 2>&1 &
fi
exit 0
